# =============================================================================
# xnft-monitor environment variables
# =============================================================================
# Copy this file to .env and fill in the values you want to use.
# .env is in .gitignore — never commit real tokens.
# =============================================================================

# --- Slack -------------------------------------------------------------------
# Create an incoming webhook at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/TXXXXXXXX/BXXXXXXXX/xxxxxxxx

# --- Discord -----------------------------------------------------------------
# Create a webhook in channel settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/000000000000/xxxxxxxx

# --- Email -------------------------------------------------------------------
# Requires 'mail' command (mailutils / s-nail). For cloud/VPS with no MTA,
# use ssmtp or msmtp pointing to an SMTP relay.
NOTIFY_EMAIL=you@yourdomain.com
NOTIFY_FROM_EMAIL=xnft-monitor@yourdomain.com

# --- Notion ------------------------------------------------------------------
# 1. Create a Notion integration at https://www.notion.so/my-integrations
# 2. Share a database page with the integration
# 3. Copy the integration token and database ID (from the page URL)
NOTION_API_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- General -----------------------------------------------------------------
# GitHub repo for links in notifications
GITHUB_REPO=paulfxyz/xnftables

# Set to 1 to run all checks without sending any notifications (testing)
DRY_RUN=0
